---
import { menuMain } from "~/data/menus.js";
import LogoContainer from "~/components/LogoContainer.astro";
---

<header>
  <div id="header-wrapper" class="fixed inset-x-0 top-0 z-40">
    <div class="container py-3 lg:py-5">
      <nav class="flex items-center justify-between gap-4 rounded-[1.75rem] border border-white/70 bg-white/80 px-4 py-3 shadow-[0_18px_45px_rgba(15,23,42,0.08)] backdrop-blur-xl lg:px-6" aria-label="Principal">
        <a href="/#inicio" class="shrink-0" aria-label="Ir al inicio de Kid Pam Pum">
          <LogoContainer />
        </a>

        <div class="hidden lg:flex items-center gap-7">
          {menuMain.map((item) => (
            <a href={item.url} class="text-sm font-semibold tracking-wide text-slate-700 transition hover:text-fuchsia-600">
              {item.name}
            </a>
          ))}
        </div>

        <a href="/#contacto" class="button button-fuchsia !rounded-full !px-5 !py-2.5 text-sm">Inscribirme</a>
      </nav>

      <div class="mt-3 overflow-x-auto lg:hidden">
        <ul class="flex min-w-max items-center gap-3 pb-1">
          {menuMain.map((item) => (
            <li>
              <a href={item.url} class="inline-flex rounded-full border border-white/70 bg-white/80 px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-orange-300 hover:text-fuchsia-600">
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const headerWrapper = document.getElementById("header-wrapper");
    if (!headerWrapper) return;

    const setHeaderHeight = () => {
      document.documentElement.style.setProperty("--header-height", `${headerWrapper.offsetHeight}px`);
    };

    setHeaderHeight();
    window.addEventListener("resize", setHeaderHeight);
  });
</script>
