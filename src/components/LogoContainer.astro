---
import { siteName, siteSlogan, siteLogo } from "~/data/config.js";
---

<div class="flex items-center gap-3 lg:gap-4">
  <div class="overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-orange-100 lg:rounded-[1.1rem]">
    <img
      src={siteLogo}
      alt={`Logo de ${siteName}`}
      class="size-10 object-cover lg:size-12"
      loading="eager"
      decoding="async"
    />
  </div>

  <div>
    <p class="font-black leading-tight text-slate-900 text-base lg:text-lg">{siteName}</p>
    <p class="text-xs lg:text-sm text-slate-600 leading-tight">{siteSlogan}</p>
  </div>
</div>
