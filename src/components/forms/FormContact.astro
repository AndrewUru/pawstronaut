---
---

<form action="#" class="space-y-5">
  <div>
    <label for="contact-name">Nombre*</label>
    <div class="mt-2">
      <input type="text" name="name" id="contact-name" required />
    </div>
  </div>

  <div>
    <label for="contact-message">Mensaje</label>
    <div class="mt-2">
      <textarea name="message" id="contact-message" rows="5"></textarea>
    </div>
  </div>

  <div class="rounded-2xl bg-orange-50 p-4">
    <label class="flex items-start gap-3" for="contact-consent">
      <input id="contact-consent" name="consent" type="checkbox" required class="mt-1 h-4 w-4 rounded border-orange-300" />
      <span class="text-xs leading-relaxed">Por la presente acepto que estos datos se almacenen y procesen con el fin de establecer contacto. Soy consciente de que puedo revocar mi consentimiento en cualquier momento</span>
    </label>
  </div>

  <p class="text-xs text-slate-500">* Rellene todos los campos obligatorios</p>

  <button type="submit" class="button button-fuchsia">Enviar</button>
</form>
