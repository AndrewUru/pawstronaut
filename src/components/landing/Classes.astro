---
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import CTA from "~/components/landing/CTA.astro";
import { instrumentos } from "~/data/site";
---

<Section id="clases">
  <Container class:list="!py-18 md:!py-24">
    <div class="mx-auto mb-12 max-w-3xl text-center md:mb-16">
      <h2 class="h2">Clases</h2>
      <p class="mt-4 text-lg md:text-xl">Programas pensados para acompañar cada etapa musical con claridad y flexibilidad.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2 lg:gap-8">
      <article class="rounded-[2rem] border border-white/80 bg-white/90 p-6 shadow-[0_20px_55px_rgba(15,23,42,0.08)] md:p-8">
        <h3>Clases para niños</h3>
        <p class="mt-3 text-base font-semibold text-fuchsia-700 md:text-lg">Clases grupales · elige tu franja horaria</p>
        <p class="mt-4 text-[15px] md:text-lg">A partir de una hora por semana. Cuanto más tiempo vengas, más aprenderás y menor será el precio por hora.</p>

        <div class="mt-7 rounded-[1.4rem] bg-[linear-gradient(180deg,#fff7ed_0%,#ffffff_100%)] p-5">
          <p class="font-bold text-slate-900">Precios</p>
          <ul class="mt-3 space-y-2 text-sm md:text-base">
            <li>1 hora / 40€</li>
            <li>1 hora y media / 55€</li>
            <li>2 horas / 70€</li>
            <li>3 horas / 90€</li>
            <li>4 horas / 110€</li>
            <li>5 horas / 125€</li>
            <li>6 horas / 140€</li>
          </ul>
        </div>

        <div class="mt-5 rounded-[1.4rem] bg-orange-50 p-5 text-sm md:text-base">
          <p class="font-bold text-slate-900">Horarios</p>
          <p class="mt-3">De 17:00 a 19:00 · Lunes, miércoles y viernes · 3 - 11 años</p>
          <p class="mt-3">De 17:00 a 19:00 · Martes y jueves · 11 - 18 años</p>
        </div>

        <CTA href="/#contacto" label="Pulsa el botón para inscribirte" class="mt-7 w-full sm:w-auto" />
      </article>

      <article class="rounded-[2rem] border border-white/80 bg-white/90 p-6 shadow-[0_20px_55px_rgba(15,23,42,0.08)] md:p-8">
        <h3>Clases para todas las edades y niveles</h3>

        <div class="mt-6 rounded-[1.4rem] bg-[linear-gradient(180deg,#fdf2f8_0%,#ffffff_100%)] p-5">
          <p class="font-bold text-slate-900">Instrumentos</p>
          <p class="mt-3 text-sm leading-7 md:text-base">{instrumentos.join(", ")}</p>
        </div>

        <div class="mt-5 rounded-[1.4rem] bg-white p-5 ring-1 ring-fuchsia-100">
          <p class="font-bold text-slate-900">Precios</p>
          <p class="mt-1 text-sm text-slate-500">Por mes · 1 hora semanal</p>
          <ul class="mt-3 space-y-2 text-sm md:text-base">
            <li>Grupal: 60€</li>
            <li>En pareja: 80€</li>
            <li>Particular: 120€</li>
          </ul>
        </div>

        <div class="mt-5 rounded-[1.4rem] bg-fuchsia-50 p-5 text-sm md:text-base">
          <p class="font-bold text-slate-900">Horarios</p>
          <p class="mt-3">Lunes y viernes · 9:00 - 12:00 · 19:00 - 21:00</p>
        </div>

        <CTA href="/#contacto" label="Pulsa el botón para inscribirte" class="mt-7 w-full sm:w-auto" />
      </article>
    </div>
  </Container>
</Section>
