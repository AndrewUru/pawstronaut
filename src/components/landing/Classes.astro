---
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import CTA from "~/components/landing/CTA.astro";
import { instrumentos } from "~/data/site";
---

<Section id="clases" class="relative overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(249,115,22,0.10),transparent_30%),radial-gradient(circle_at_85%_20%,rgba(217,70,239,0.10),transparent_30%)]"></div>

  <Container class:list="!py-18 md:!py-24">
    <div class="mx-auto mb-12 max-w-3xl text-center md:mb-16">
      <span class="inline-flex rounded-full border border-orange-200 bg-orange-50 px-4 py-1 text-sm font-semibold text-orange-700">
        Programas y horarios
      </span>
      <h2 class="h2 mt-4">Clases</h2>
      <p class="mt-4 text-lg md:text-xl">
        Programas pensados para acompañar cada etapa musical con claridad, flexibilidad y una experiencia motivadora.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2 lg:gap-8">
      <!-- CARD 1 -->
      <article class="rounded-[2rem] border border-white/80 bg-white/95 p-6 shadow-[0_20px_55px_rgba(15,23,42,0.08)] backdrop-blur md:p-8">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <span class="inline-flex rounded-full bg-fuchsia-50 px-3 py-1 text-sm font-semibold text-fuchsia-700">
              Infantil y juvenil
            </span>
            <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-900">
              Clases para niños y adolescentes
            </h3>
            <p class="mt-3 text-base font-semibold text-fuchsia-700 md:text-lg">
              Clases grupales · elige tu franja horaria
            </p>
          </div>

          <div class="rounded-2xl bg-slate-900 px-4 py-3 text-white shadow-lg">
            <p class="text-xs uppercase tracking-[0.18em] text-white/70">Desde</p>
            <p class="text-3xl font-bold leading-none">40€</p>
            <p class="mt-1 text-sm text-white/70">al mes</p>
          </div>
        </div>

        <p class="mt-5 text-[15px] leading-7 text-slate-700 md:text-lg">
          A partir de una hora por semana. Cuanto más tiempo vengas, más aprenderás y menor será el precio por hora.
        </p>

        <div class="mt-7 grid gap-4">
          <div class="rounded-[1.5rem] border border-orange-100 bg-[linear-gradient(180deg,#fff7ed_0%,#ffffff_100%)] p-5">
            <div class="flex items-center justify-between gap-3">
              <p class="text-base font-bold text-slate-900 md:text-lg">Precios</p>
              <span class="rounded-full bg-orange-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-orange-700">
                Mensualidad
              </span>
            </div>

            <ul class="mt-4 grid gap-3 sm:grid-cols-2">
              <li class="flex items-center justify-between rounded-2xl bg-white px-4 py-3 shadow-sm ring-1 ring-orange-100">
                <span class="font-medium text-slate-700">1 hora</span>
                <span class="text-lg font-bold text-slate-900">40€</span>
              </li>
              <li class="flex items-center justify-between rounded-2xl bg-white px-4 py-3 shadow-sm ring-1 ring-orange-100">
                <span class="font-medium text-slate-700">1,5 horas</span>
                <span class="text-lg font-bold text-slate-900">55€</span>
              </li>
              <li class="flex items-center justify-between rounded-2xl bg-white px-4 py-3 shadow-sm ring-1 ring-orange-100">
                <span class="font-medium text-slate-700">2 horas</span>
                <span class="text-lg font-bold text-slate-900">70€</span>
              </li>
              <li class="flex items-center justify-between rounded-2xl bg-white px-4 py-3 shadow-sm ring-1 ring-orange-100">
                <span class="font-medium text-slate-700">3 horas</span>
                <span class="text-lg font-bold text-slate-900">90€</span>
              </li>
              <li class="flex items-center justify-between rounded-2xl bg-white px-4 py-3 shadow-sm ring-1 ring-orange-100">
                <span class="font-medium text-slate-700">4 horas</span>
                <span class="text-lg font-bold text-slate-900">110€</span>
              </li>
              <li class="flex items-center justify-between rounded-2xl bg-white px-4 py-3 shadow-sm ring-1 ring-orange-100">
                <span class="font-medium text-slate-700">5 horas</span>
                <span class="text-lg font-bold text-slate-900">125€</span>
              </li>
              <li class="flex items-center justify-between rounded-2xl bg-white px-4 py-3 shadow-sm ring-1 ring-orange-100 sm:col-span-2">
                <span class="font-medium text-slate-700">6 horas</span>
                <span class="text-lg font-bold text-slate-900">140€</span>
              </li>
            </ul>
          </div>

          <div class="rounded-[1.5rem] border border-fuchsia-100 bg-fuchsia-50/70 p-5">
            <div class="flex items-center justify-between gap-3">
              <p class="text-base font-bold text-slate-900 md:text-lg">Horarios</p>
              <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wide text-fuchsia-700 ring-1 ring-fuchsia-100">
                Por edades
              </span>
            </div>

            <div class="mt-4 grid gap-3">
              <div class="rounded-2xl bg-white px-4 py-4 ring-1 ring-fuchsia-100">
                <p class="font-semibold text-slate-900">Niños</p>
                <p class="mt-1 text-sm text-slate-600">Lunes, miércoles y viernes · 17:00 – 19:00</p>
                <p class="mt-1 text-sm font-medium text-fuchsia-700">3 a 11 años</p>
              </div>

              <div class="rounded-2xl bg-white px-4 py-4 ring-1 ring-fuchsia-100">
                <p class="font-semibold text-slate-900">Adolescentes</p>
                <p class="mt-1 text-sm text-slate-600">Martes y jueves · 17:00 – 19:00</p>
                <p class="mt-1 text-sm font-medium text-fuchsia-700">11 a 18 años</p>
              </div>
            </div>
          </div>
        </div>

        <CTA href="/#contacto" label="Pulsa el botón para inscribirte" class="mt-7 w-full sm:w-auto" />
      </article>

      <!-- CARD 2 -->
      <article class="rounded-[2rem] border border-white/80 bg-white/95 p-6 shadow-[0_20px_55px_rgba(15,23,42,0.08)] backdrop-blur md:p-8">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <span class="inline-flex rounded-full bg-orange-50 px-3 py-1 text-sm font-semibold text-orange-700">
              Individual, pareja o grupo
            </span>
            <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-900">
              Clases para todas las edades y niveles
            </h3>
          </div>

          <div class="rounded-2xl bg-slate-900 px-4 py-3 text-white shadow-lg">
            <p class="text-xs uppercase tracking-[0.18em] text-white/70">Desde</p>
            <p class="text-3xl font-bold leading-none">60€</p>
            <p class="mt-1 text-sm text-white/70">al mes</p>
          </div>
        </div>

        <div class="mt-7 rounded-[1.5rem] border border-fuchsia-100 bg-[linear-gradient(180deg,#fdf2f8_0%,#ffffff_100%)] p-5">
          <div class="flex items-center justify-between gap-3">
            <p class="text-base font-bold text-slate-900 md:text-lg">Instrumentos</p>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wide text-fuchsia-700 ring-1 ring-fuchsia-100">
              A elegir
            </span>
          </div>

          <p class="mt-4 text-sm leading-7 text-slate-700 md:text-base">
            {instrumentos.join(", ")}
          </p>
        </div>

        <div class="mt-5 rounded-[1.5rem] border border-orange-100 bg-white p-5 ring-1 ring-orange-50">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-base font-bold text-slate-900 md:text-lg">Precios</p>
              <p class="mt-1 text-sm text-slate-500">Por mes · 1 hora semanal</p>
            </div>
            <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-orange-700">
              Flexible
            </span>
          </div>

          <ul class="mt-4 grid gap-3">
            <li class="flex items-center justify-between rounded-2xl bg-orange-50/60 px-4 py-3">
              <span class="font-medium text-slate-700">Grupal</span>
              <span class="text-lg font-bold text-slate-900">60€</span>
            </li>
            <li class="flex items-center justify-between rounded-2xl bg-orange-50/60 px-4 py-3">
              <span class="font-medium text-slate-700">En pareja</span>
              <span class="text-lg font-bold text-slate-900">80€</span>
            </li>
            <li class="flex items-center justify-between rounded-2xl bg-orange-50/60 px-4 py-3">
              <span class="font-medium text-slate-700">Particular</span>
              <span class="text-lg font-bold text-slate-900">120€</span>
            </li>
          </ul>
        </div>

        <div class="mt-5 rounded-[1.5rem] border border-fuchsia-100 bg-fuchsia-50/70 p-5">
          <div class="flex items-center justify-between gap-3">
            <p class="text-base font-bold text-slate-900 md:text-lg">Horarios</p>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wide text-fuchsia-700 ring-1 ring-fuchsia-100">
              Mañana y tarde
            </span>
          </div>

          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl bg-white px-4 py-4 ring-1 ring-fuchsia-100">
              <p class="font-semibold text-slate-900">Mañanas</p>
              <p class="mt-1 text-sm text-slate-600">Lunes y viernes</p>
              <p class="mt-1 text-sm font-medium text-fuchsia-700">9:00 – 12:00</p>
            </div>

            <div class="rounded-2xl bg-white px-4 py-4 ring-1 ring-fuchsia-100">
              <p class="font-semibold text-slate-900">Tardes</p>
              <p class="mt-1 text-sm text-slate-600">Lunes y viernes</p>
              <p class="mt-1 text-sm font-medium text-fuchsia-700">19:00 – 21:00</p>
            </div>
          </div>
        </div>

        <CTA href="/#contacto" label="Pulsa el botón para inscribirte" class="mt-7 w-full sm:w-auto" />
      </article>
    </div>
  </Container>
</Section>