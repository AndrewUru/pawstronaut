---
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import CTA from "~/components/landing/CTA.astro";

const contactBackground = "/images/fachada-contact.jpg"; // reemplaza por foto de la fachada cuando la tengas
---

<Section id="contacto" class="relative overflow-hidden">
  <div
    class="absolute inset-0 -z-10 bg-cover bg-center"
    style={`background-image: url('${contactBackground}');`}
    aria-hidden="true"
  ></div>
  <div class="absolute inset-0 -z-5 bg-[linear-gradient(120deg,rgba(15,23,42,0.7),rgba(47,61,224,0.45))]"></div>

  <Container class:list="relative z-10 !py-18 md:!py-24">
    <div class="mx-auto mb-12 max-w-3xl text-center md:mb-16">
      <h2 class="h2 text-white">Contacto</h2>
      <p class="mt-4 text-lg text-white/85 md:text-xl">Te ayudamos a encontrar la clase ideal para empezar hoy mismo.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[.95fr_1.05fr] lg:gap-8">
      <aside class="rounded-[2rem] border border-white/40 bg-white/85 p-6 shadow-[0_18px_45px_rgba(15,23,42,0.16)] backdrop-blur md:p-8">
        <h3 class="text-2xl md:text-[1.95rem]">Datos de contacto</h3>
        <div class="mt-6 space-y-4 text-sm leading-7 md:text-base">
          <p><strong>Teléfono:</strong> <a href="tel:+34633796409" class="text-fuchsia-700 hover:underline">633796409</a></p>
          <p><strong>Correo electrónico:</strong> <a href="mailto:kidpampum@hotmail.com" class="text-fuchsia-700 hover:underline">kidpampum@hotmail.com</a></p>
          <p><strong>Dirección:</strong> Calle Gibraltar 31, Valencia, 46005, Valencia, España</p>
        </div>

        <CTA
          href="https://wa.me/34633796409?text=Hola%20Kid%20Pam%20Pum%2C%20quiero%20informaci%C3%B3n%20sobre%20las%20clases."
          label="Escribir por WhatsApp"
          variant="teal"
          newtab={true}
          class="mt-7 w-full"
        />
      </aside>

      <div class="rounded-[2rem] border border-white/40 bg-white/85 p-6 shadow-[0_18px_45px_rgba(15,23,42,0.16)] backdrop-blur md:p-8">
        <h3 class="text-2xl md:text-[1.95rem]">Formulario de contacto</h3>

        <form id="contact-form" class="mt-7 space-y-5">
          <div>
            <label for="nombre">Nombre*</label>
            <div class="mt-2">
              <input id="nombre" name="nombre" type="text" required />
            </div>
          </div>

          <div>
            <label for="mensaje">Mensaje</label>
            <div class="mt-2">
              <textarea id="mensaje" name="mensaje" rows="5"></textarea>
            </div>
          </div>

          <div class="rounded-[1.4rem] bg-orange-50 p-4 md:p-5">
            <label class="flex items-start gap-3" for="consentimiento">
              <input id="consentimiento" name="consentimiento" type="checkbox" required class="mt-1 h-4 w-4 rounded border-orange-300" />
              <span class="text-xs leading-relaxed">Por la presente acepto que estos datos se almacenen y procesen con el fin de establecer contacto. Soy consciente de que puedo revocar mi consentimiento en cualquier momento</span>
            </label>
          </div>

          <p class="text-xs text-slate-500">* Rellene todos los campos obligatorios</p>

          <button type="submit" class="button button-fuchsia w-full sm:w-auto">Enviar por WhatsApp</button>
        </form>
      </div>
    </div>
  </Container>
</Section>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form");
    if (!(form instanceof HTMLFormElement)) return;

    form.addEventListener("submit", (event) => {
      event.preventDefault();

      const nameInput = form.querySelector("#nombre");
      const messageInput = form.querySelector("#mensaje");
      const consentInput = form.querySelector("#consentimiento");

      if (
        !(nameInput instanceof HTMLInputElement) ||
        !(messageInput instanceof HTMLTextAreaElement) ||
        !(consentInput instanceof HTMLInputElement) ||
        !consentInput.checked
      ) {
        return;
      }

      const name = nameInput.value.trim();
      const message = messageInput.value.trim();
      const whatsappMessage = `Hola Kid Pam Pum, soy ${name}. ${message || "Quiero información sobre las clases."}`;
      const whatsappUrl = `https://wa.me/34633796409?text=${encodeURIComponent(whatsappMessage)}`;

      window.open(whatsappUrl, "_blank", "noopener,noreferrer");
    });
  });
</script>
