---
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import CTA from "~/components/landing/CTA.astro";
import { downloads } from "~/data/site";
---

<Section>
  <Container class:list="!py-18 md:!py-24">
    <div class="mx-auto mb-12 max-w-3xl text-center md:mb-16">
      <h2 class="h2">Folletos y descargas</h2>
      <p class="mt-4 text-lg md:text-xl">Descarga la información de cada modalidad y compártela fácilmente.</p>
    </div>

    <div class="grid gap-5 md:grid-cols-3 lg:gap-7">
      {
        downloads.map((item) => (
          <article class="rounded-[1.75rem] border border-white/80 bg-white/90 p-6 shadow-[0_18px_45px_rgba(15,23,42,0.06)] md:p-7">
            <h3 class="text-xl md:text-[1.65rem]">{item.title}</h3>
            <p class="mt-4 text-sm leading-7 md:text-base">{item.description}</p>
            <CTA href={item.href} label="Descargar folleto" variant="teal" class="mt-6 w-full sm:w-auto" />
          </article>
        ))
      }
    </div>
  </Container>
</Section>
