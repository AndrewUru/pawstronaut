---
const { title, description, class: className = "" } = Astro.props;
---

<article class={`rounded-[1.75rem] border border-white/80 bg-white/90 p-6 shadow-[0_18px_45px_rgba(15,23,42,0.06)] md:p-7 ${className}`}>
  <h3 class="text-2xl md:text-[1.9rem]">{title}</h3>
  <p class="mt-4 text-base md:text-lg">{description}</p>
</article>
