---
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import CTA from "~/components/landing/CTA.astro";
import { instrumentos } from "~/data/site";
---

<Section id="colegios" class="bg-white/70">
  <Container class:list="!py-18 md:!py-24">
    <article class="mx-auto max-w-5xl rounded-[2rem] border border-white/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.95)_0%,rgba(255,247,237,0.98)_100%)] p-7 shadow-[0_24px_60px_rgba(15,23,42,0.08)] lg:p-10">
      <h2 class="h3">Clases en colegios</h2>
      <p class="mt-3 text-base font-semibold text-fuchsia-700 md:text-lg">Infantil y Primaria</p>
      <p class="mt-4 max-w-2xl text-[15px] md:text-lg">Comprometidos con la educación pública.</p>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        <div class="rounded-[1.4rem] bg-white/80 p-5 shadow-sm">
          <p class="font-bold text-slate-900">Instrumentos</p>
          <p class="mt-3 text-sm leading-7 md:text-base">{instrumentos.join(", ")}</p>
        </div>
        <div class="rounded-[1.4rem] bg-white/80 p-5 shadow-sm">
          <p class="font-bold text-slate-900">Precios</p>
          <p class="mt-1 text-sm text-slate-500">Mensualidad por semana</p>
          <p class="mt-3 text-sm md:text-base">1 día: 30€</p>
          <p class="mt-1 text-sm md:text-base">2 días: 35€</p>
        </div>
        <div class="rounded-[1.4rem] bg-white/80 p-5 shadow-sm">
          <p class="font-bold text-slate-900">Horarios</p>
          <p class="mt-3 text-sm md:text-base">Lunes y viernes</p>
          <p class="mt-1 text-sm md:text-base">12:45 - 16:30</p>
          <p class="mt-1 text-sm md:text-base">Distribuido en diferentes edades</p>
        </div>
      </div>

      <CTA href="/#contacto" label="Pulsa el botón para inscribirte" class="mt-8 w-full sm:w-auto" />
    </article>
  </Container>
</Section>
