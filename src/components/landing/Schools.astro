---
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import CTA from "~/components/landing/CTA.astro";
import { instrumentos } from "~/data/site";

const schoolBackground =
  "https://www.kidpampum.com/wp-content/uploads/go-x/u/f1ba8a91-e73b-4d76-97a7-6e48f1b9895d/l438,t0,w1125,h1125/image-480x480.jpg";
---

<Section id="colegios" class="relative overflow-hidden bg-white/70">
  <div
    class="absolute inset-0 -z-10 bg-cover bg-center"
    style={`background-image: url('${schoolBackground}');`}
    aria-hidden="true"
  ></div>
  <div class="absolute inset-0 -z-5 bg-[linear-gradient(120deg,rgba(47,61,224,0.65),rgba(225,29,141,0.4))]"></div>

  <Container class:list="relative z-10 !py-18 md:!py-24">
    <article class="mx-auto max-w-5xl rounded-[2rem] border border-white/40 bg-white/85 p-7 shadow-[0_24px_60px_rgba(15,23,42,0.18)] backdrop-blur lg:p-10">
      <h2 class="h3">Clases en colegios</h2>
      <p class="mt-3 text-base font-semibold text-secondary md:text-lg">Infantil y Primaria</p>
      <p class="mt-4 max-w-2xl text-[15px] text-slate-700 md:text-lg">Comprometidos con la educación pública.</p>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        <div class="rounded-[1.4rem] bg-white p-5 shadow-sm ring-1 ring-primary/10">
          <p class="font-bold text-slate-900">Instrumentos</p>
          <p class="mt-3 text-sm leading-7 md:text-base">{instrumentos.join(", ")}</p>
        </div>
        <div class="rounded-[1.4rem] bg-white p-5 shadow-sm ring-1 ring-primary/10">
          <p class="font-bold text-slate-900">Precios</p>
          <p class="mt-1 text-sm text-slate-500">Mensualidad por semana</p>
          <p class="mt-3 text-sm md:text-base font-bold text-secondary">1 día: 30€</p>
          <p class="mt-1 text-sm md:text-base font-bold text-secondary">2 días: 35€</p>
        </div>
        <div class="rounded-[1.4rem] bg-white p-5 shadow-sm ring-1 ring-primary/10">
          <p class="font-bold text-slate-900">Horarios</p>
          <p class="mt-3 text-sm md:text-base">Lunes y viernes</p>
          <p class="mt-1 text-sm md:text-base">12:45 - 16:30</p>
          <p class="mt-1 text-sm md:text-base">Distribuido en diferentes edades</p>
        </div>
      </div>

      <CTA href="/#contacto" label="Pulsa el botón para inscribirte" class="mt-8 w-full sm:w-auto" />
    </article>
  </Container>
</Section>
