---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}
---

<Layout pageTitle="Novedad | Kid Pam Pum" title="Novedad | Kid Pam Pum" description="Contenido de novedades de Kid Pam Pum.">
  <Section>
    <Container>
      <div class="mx-auto max-w-3xl rounded-3xl border border-orange-100 bg-white p-8 text-center shadow-sm">
        <h1 class="h3">Contenido en actualización</h1>
        <p class="mt-4">Estamos reorganizando esta página para alinearla con la nueva web de Kid Pam Pum.</p>
        <a href="/#inicio" class="button button-fuchsia mt-8">Volver al inicio</a>
      </div>
    </Container>
  </Section>
</Layout>
