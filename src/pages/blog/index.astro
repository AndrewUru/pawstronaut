---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
---

<Layout pageTitle="Novedades | Kid Pam Pum" title="Novedades | Kid Pam Pum" description="Novedades y noticias de Kid Pam Pum.">
  <Section>
    <Container>
      <div class="mx-auto max-w-3xl rounded-3xl border border-orange-100 bg-white p-8 text-center shadow-sm">
        <h1 class="h2">Novedades</h1>
        <p class="mt-4">Estamos preparando esta sección con noticias y actividades de La Casita Musical.</p>
        <a href="/#inicio" class="button button-fuchsia mt-8">Volver al inicio</a>
      </div>
    </Container>
  </Section>
</Layout>
