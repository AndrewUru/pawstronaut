---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import FormContact from "~/components/forms/FormContact.astro";
import Map from "~/components/Map.astro";
---

<Layout pageTitle="Contacto | Kid Pam Pum" title="Contacto | Kid Pam Pum" description="Pide información sobre clases y matrículas en Kid Pam Pum.">
  <Section>
    <Container>
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="rounded-3xl border border-orange-100 bg-white p-7 shadow-sm">
          <h1 class="h3">Contacto</h1>
          <p class="mt-3">Escríbenos y te orientamos sobre la clase ideal para tu edad y nivel.</p>
          <div class="mt-6 space-y-2 text-sm">
            <p><strong>Teléfono:</strong> 633796409</p>
            <p><strong>Email:</strong> kidpampum@hotmail.com</p>
            <p><strong>Dirección:</strong> Calle Gibraltar 31, Valencia, 46005, Valencia, España</p>
          </div>

          <div class="mt-8">
            <FormContact />
          </div>
        </div>

        <div class="rounded-3xl border border-orange-100 bg-white p-4 shadow-sm">
          <Map />
        </div>
      </div>
    </Container>
  </Section>
</Layout>
